---
layout: layouts/base.njk
title: Explore
permalink: /explore/
---

<article class="page">
  <header class="page-header">
    <h1 class="page-title">Explore</h1>
  </header>
  <div class="page-content">

    <div class="section-tabs works-tabs">
      <button class="section-tab active" data-explore-tab="categories">Categories</button>
      <button class="section-tab" data-explore-tab="tags">Tags</button>
      <button class="section-tab" data-explore-tab="archives">Archives</button>
    </div>

    {# ── Categories Tab ── #}
    <div class="explore-panel" id="explore-categories">
      <div class="category-tree">
        {% set catMap = collections.categoryMap %}
        {% for catName, posts in catMap %}
        <div class="category-branch">
          <a href="/categories/{{ catName }}/" class="category-branch-header">
            <i class="fa-solid fa-folder"></i>
            <span class="category-branch-name">{{ catName }}</span>
            <span class="category-branch-count">{{ posts.length }}</span>
          </a>
          <div class="category-branch-posts">
            {% for post in posts | reverse %}
            <a href="{{ post.url }}" class="category-branch-post">
              <span class="category-branch-post-title">{{ post.data.title }}</span>
              <time class="category-branch-post-date">{{ post.date | readableDate }}</time>
            </a>
            {% endfor %}
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

    {# ── Tags Tab ── #}
    <div class="explore-panel" id="explore-tags" hidden>
      <div class="tags-grid">
        {% for tag in collections.tagList %}
          {% set tagCount = collections[tag].length if collections[tag] else 0 %}
          {% if tagCount > 0 %}
          <a href="/tags/{{ tag | slugify }}/" class="tag-card">
            <span class="tag-card-name">{{ tag }}</span>
            <span class="tag-card-count">{{ tagCount }} {{ "post" if tagCount == 1 else "posts" }}</span>
          </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {# ── Archives Tab ── #}
    <div class="explore-panel" id="explore-archives" hidden>
      <div class="archives">
        {% set yearGroups = collections.allPosts | groupByYear %}
        {% for group in yearGroups %}
          <h2 class="archives-year">{{ group.year }}</h2>
          <ul class="archives-list">
            {% for post in group.posts %}
            <li class="archives-item">
              <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
              <a href="{{ post.url }}">{{ post.data.title }}</a>
            </li>
            {% endfor %}
          </ul>
        {% endfor %}
      </div>
    </div>

  </div>
</article>
