---
layout: layouts/page.njk
pagination:
  data: collections.categoryList
  size: 1
  alias: category
permalink: "/categories/{{ category }}/"
eleventyComputed:
  title: "Category: {{ category }}"
---

<div class="post-list">
  {% set catPosts = collections.categoryMap[category] %}
  {% for post in catPosts %}
  <article class="post-card">
    <div class="post-card-sections">
      {% set postSecs = post | postSections %}
      {{ postSecs | join(" · ") | upper }}
    </div>
    <h2 class="post-card-title">
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </h2>
    <div class="post-card-meta">
      <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
    </div>
  </article>
  {% endfor %}
</div>
