{# Mobile top bar #}
<div class="topbar">
  <div class="topbar-left">
    <img src="{{ site.avatar }}" alt="{{ site.author.name }}" class="topbar-avatar">
    <span class="topbar-title">{{ site.author.name }}</span>
  </div>
  <button class="hamburger" aria-label="Toggle navigation">
    <i class="fa-solid fa-bars"></i>
  </button>
</div>
<div class="sidebar-overlay"></div>

<aside class="sidebar">
  <div class="sidebar-inner">
    <div class="sidebar-profile">
      <a href="/"><img src="{{ site.avatar }}" alt="{{ site.author.name }}" class="sidebar-avatar"></a>
      <h1 class="sidebar-title">{{ site.title }}</h1>
      <p class="sidebar-tagline">{{ site.tagline }}</p>
      <a href="{{ site.bookLink }}" class="sidebar-book-link" target="_blank" rel="noopener">📖 my book — Deep Dive Python</a>
    </div>
    <hr class="sidebar-divider">
    <nav class="sidebar-nav">
      {% for item in navigation %}
      <a href="{{ item.url }}" class="sidebar-nav-item{% if page.url == item.url %} active{% endif %}">
        <i class="{{ item.icon }}"></i><span>{{ item.label }}</span>
      </a>
      {% endfor %}
    </nav>
    <div class="sidebar-bottom">
      <a href="https://www.python.org/psf/membership/" target="_blank" rel="noopener" class="psf-badge">
        <img src="/assets/img/profile/PSF_Supporting_Member_badge.png" alt="PSF Supporting Member">
      </a>
      <div class="sidebar-social">
        {% for link in social %}
        <a href="{{ link.url }}" title="{{ link.label }}" {% if link.url | string | truncate(4, false, '') == "http" %}target="_blank" rel="noopener"{% endif %}>
          <i class="{{ link.icon }}"></i>
        </a>
        {% endfor %}
      </div>
      <button class="theme-toggle" aria-label="Toggle theme"><i class="fa-solid fa-moon"></i></button>
    </div>
  </div>
</aside>
