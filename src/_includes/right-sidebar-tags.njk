<aside class="right-sidebar">
  <div class="right-sidebar-inner">
    <div class="aside-section aside-profile-section">
      <h3 class="aside-heading">About</h3>
      <a href="/"><img src="{{ site.avatar }}" alt="{{ site.author.name }}" class="aside-avatar"></a>
      <div class="aside-name">{{ site.title }}</div>
      <div class="aside-bio">{{ site.tagline }}</div>
      <a href="{{ site.bookLink }}" class="aside-book" target="_blank" rel="noopener">
        <i class="fa-solid fa-book"></i> My Book: Deep Dive Python
      </a>
    </div>
    <div class="aside-section">
      <h3 class="aside-heading">Tags</h3>
      <div class="tag-cloud">
        {% for tag in collections.tagList %}
          {% set tagCount = collections[tag].length if collections[tag] else 0 %}
          {% if tagCount > 0 %}
          <a href="/tags/{{ tag | slugify }}/" class="tag-pill">{{ tag }} <span class="tag-count">{{ tagCount }}</span></a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    <div class="aside-section">
      <h3 class="aside-heading">Sections</h3>
      <div class="sections-nav">
        {% set pyCount = collections.sectionPython | size %}
        {% set aiCount = collections.sectionAi | size %}
        {% set personalCount = collections.sectionPersonal | size %}
        {% if pyCount > 0 %}
        <a href="/python/" class="section-card">
          <i class="fa-brands fa-python"></i> Python
          <span class="section-count">{{ pyCount }} posts</span>
        </a>
        {% endif %}
        {% if aiCount > 0 %}
        <a href="/ai/" class="section-card">
          <i class="fa-solid fa-robot"></i> AI
          <span class="section-count">{{ aiCount }} posts</span>
        </a>
        {% endif %}
        {% if personalCount > 0 %}
        <a href="/personal/" class="section-card">
          <i class="fa-solid fa-pen-nib"></i> Personal
          <span class="section-count">{{ personalCount }} posts</span>
        </a>
        {% endif %}
      </div>
    </div>
    <div class="aside-section">
      <h3 class="aside-heading">Subscribe</h3>
      <a href="/feed/all.xml" class="subscribe-link"><i class="fa-solid fa-rss"></i> All posts feed</a>
    </div>
  </div>
</aside>
