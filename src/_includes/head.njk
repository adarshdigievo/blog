<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

{# Title #}
{% if title %}
<title>{{ title }} | {{ site.title }}</title>
{% else %}
<title>{{ site.title }}</title>
{% endif %}

{# Meta description #}
{% set metaDesc = description or autoExcerpt or site.description %}
<meta name="description" content="{{ metaDesc }}">

<meta name="author" content="{{ site.author.name }}">
<meta name="robots" content="{{ robots if robots else 'index, follow' }}">

{# Canonical URL #}
<link rel="canonical" href="{{ site.url }}{{ page.url }}">

{# Pagination rel links #}
{% if pagination and pagination.href.previous %}
<link rel="prev" href="{{ site.url }}{{ pagination.href.previous }}">
{% endif %}
{% if pagination and pagination.href.next %}
<link rel="next" href="{{ site.url }}{{ pagination.href.next }}">
{% endif %}

{# Open Graph #}
<meta property="og:title" content="{% if title %}{{ title }}{% else %}{{ site.title }}{% endif %}">
<meta property="og:description" content="{{ metaDesc }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:type" content="{% if layout == 'layouts/post.njk' %}article{% else %}website{% endif %}">
{% if image %}
<meta property="og:image" content="{{ site.url }}{{ image }}">
{% else %}
<meta property="og:image" content="{{ site.url }}{{ site.avatar }}">
{% endif %}
<meta property="og:site_name" content="{{ site.title }}">
{% if layout == 'layouts/post.njk' %}
<meta property="article:published_time" content="{{ page.date | isoDate }}">
<meta property="article:author" content="{{ site.author.name }}">
{% if tags %}{% for tag in tags %}{% if tag != "posts" %}
<meta property="article:tag" content="{{ tag }}">
{% endif %}{% endfor %}{% endif %}
{% endif %}

{# Twitter Cards #}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@adarshd905">
<meta name="twitter:creator" content="@adarshd905">
<meta name="twitter:title" content="{% if title %}{{ title }}{% else %}{{ site.title }}{% endif %}">
<meta name="twitter:description" content="{{ metaDesc }}">
{% if image %}
<meta name="twitter:image" content="{{ site.url }}{{ image }}">
{% else %}
<meta name="twitter:image" content="{{ site.url }}{{ site.avatar }}">
{% endif %}

{# JSON-LD Structured Data #}
{% if layout == 'layouts/post.njk' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ title | replace('"', '&quot;') }}",
  "datePublished": "{{ page.date | isoDate }}",
  "dateModified": "{% if lastModified %}{{ lastModified | isoDate }}{% else %}{{ page.date | isoDate }}{% endif %}",
  "author": {
    "@type": "Person",
    "name": "{{ site.author.name }}"
  },
  "description": "{{ metaDesc | replace('"', '&quot;') }}",
  "url": "{{ site.url }}{{ page.url }}",
  "publisher": {
    "@type": "Person",
    "name": "{{ site.author.name }}",
    "url": "{{ site.url }}",
    "sameAs": [
      "https://github.com/adarshdigievo",
      "https://www.linkedin.com/in/adarsh-d",
      "https://x.com/adarshd905"
    ]
  }
}
</script>
{% else %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "{{ site.title }}",
  "url": "{{ site.url }}",
  "description": "{{ site.description }}",
  "author": {
    "@type": "Person",
    "name": "{{ site.author.name }}",
    "url": "{{ site.url }}",
    "sameAs": [
      "https://github.com/adarshdigievo",
      "https://www.linkedin.com/in/adarsh-d",
      "https://x.com/adarshd905"
    ]
  }
}
</script>
{% endif %}

{# RSS Feed Autodiscovery #}
<link rel="alternate" type="application/atom+xml" title="{{ site.title }} — All Posts" href="{{ site.url }}{% if feedUrl %}{{ feedUrl }}{% else %}/feed/all.xml{% endif %}">

{# Google Analytics #}
{% if site.google_analytics %}
<script async src="https://www.googletagmanager.com/gtag/js?id={{ site.google_analytics }}"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '{{ site.google_analytics }}');
</script>
{% endif %}

{# Google Site Verification #}
{% if site.google_site_verification %}
<meta name="google-site-verification" content="{{ site.google_site_verification }}">
{% endif %}

{# Favicons #}
<link rel="apple-touch-icon" sizes="180x180" href="/assets/img/favicons/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/assets/img/favicons/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/assets/img/favicons/favicon-16x16.png">
<link rel="manifest" href="/assets/img/favicons/site.webmanifest">
<link rel="shortcut icon" href="/assets/img/favicons/favicon.ico">

{# Fonts #}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Literata:opsz,wght@7..72,400;7..72,600;7..72,700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">

{# Stylesheet #}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">
<link rel="stylesheet" href="/css/style.css">
