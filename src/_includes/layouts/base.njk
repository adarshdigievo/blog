<!DOCTYPE html>
<html lang="{{ site.lang }}" {% if theme %}data-theme="{{ theme }}"{% endif %}>
<head>
  {% include "head.njk" %}
</head>
<body>
  <div class="layout">
    {% include "sidebar.njk" %}
    <main class="main-content">
      {{ content | safe }}
    </main>
    {% if rightSidebar == "tags" %}
      {% include "right-sidebar-tags.njk" %}
    {% elif rightSidebar == "post" %}
      {% include "right-sidebar-post.njk" %}
    {% endif %}
  </div>
  <script src="/js/main.js"></script>
</body>
</html>
