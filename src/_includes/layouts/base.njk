<!DOCTYPE html>
<html lang="{{ site.lang }}" {% if theme %}data-theme="{{ theme }}"{% endif %}>
<head>
  {% include "head.njk" %}
</head>
<body>
  {% include "header.njk" %}
  <div class="layout">
    <main class="main-content">
      {{ content | safe }}
    </main>
    {% if rightSidebar == "tags" %}
      {% include "right-sidebar-tags.njk" %}
    {% elif rightSidebar == "post" %}
      {% include "right-sidebar-post.njk" %}
    {% endif %}
  </div>
  <button class="sidebar-toggle" title="Hide sidebar" aria-label="Hide sidebar">
    <i class="fa-solid fa-chevron-right"></i>
  </button>
  <button class="sidebar-show-toggle" title="Show sidebar" aria-label="Show sidebar">
    <i class="fa-solid fa-chevron-left"></i>
  </button>
  {% include "footer.njk" %}
  <script src="/js/main.js"></script>
</body>
</html>
