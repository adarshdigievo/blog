---
layout: layouts/base.njk
rightSidebar: tags
---

<header class="section-header">
  <h1 class="section-title">{{ sectionTitle }}</h1>
  <div class="section-feed">
    <i class="fa-solid fa-rss"></i>
    <a href="{{ sectionFeedUrl }}">Subscribe to {{ sectionTitle }} feed</a>
  </div>
</header>

<div class="section-tabs">
  <a href="/" class="section-tab">All</a>
  {% if collections.sectionPython | size > 0 %}<a href="/python/" class="section-tab{% if sectionSlug == 'python' %} active{% endif %}">Python</a>{% endif %}
  {% if collections.sectionAi | size > 0 %}<a href="/ai/" class="section-tab{% if sectionSlug == 'ai' %} active{% endif %}">AI</a>{% endif %}
  {% if collections.sectionPersonal | size > 0 %}<a href="/personal/" class="section-tab{% if sectionSlug == 'personal' %} active{% endif %}">Personal</a>{% endif %}
</div>

<div class="post-list">
  {% for post in pagination.items %}
  <article class="post-card">
    <div class="post-card-sections">
      {% set sections = post | postSections %}
      {{ sections | join(" · ") | upper }}
    </div>
    <h2 class="post-card-title">
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </h2>
    <div class="post-card-meta">
      <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
      <span class="separator">·</span>
      <span>{{ post.content | readingTime }}</span>
    </div>
    {% if post.data.tags %}
    <div class="post-card-tags">
      {% for tag in post.data.tags %}
      <a href="/tags/{{ tag | slugify }}/" class="tag-pill small">{{ tag }}</a>
      {% endfor %}
    </div>
    {% endif %}
  </article>
  {% endfor %}
</div>

{% include "pagination.njk" %}
