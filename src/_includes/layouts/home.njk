---
layout: layouts/base.njk
rightSidebar: tags
---

<div class="section-tabs">
  <a href="/" class="section-tab active">All</a>
  <a href="/python/" class="section-tab">Python</a>
  <a href="/ai/" class="section-tab">AI</a>
  <a href="/personal/" class="section-tab">Personal</a>
</div>

<div class="post-list">
  {% for post in pagination.items %}
  <article class="post-card">
    <div class="post-card-sections">
      {% set sections = post | postSections %}
      {{ sections | join(" · ") | upper }}
    </div>
    <h2 class="post-card-title">
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </h2>
    <div class="post-card-meta">
      <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
      <span class="separator">·</span>
      <span>{{ post.content | readingTime }}</span>
    </div>
    {% if post.data.tags %}
    <div class="post-card-tags">
      {% for tag in post.data.tags %}
      <a href="/tags/{{ tag | slugify }}/" class="tag-pill small">{{ tag }}</a>
      {% endfor %}
    </div>
    {% endif %}
  </article>
  {% endfor %}
</div>

{% include "pagination.njk" %}
